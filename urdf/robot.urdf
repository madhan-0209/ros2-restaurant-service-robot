<?xml version="1.0"?>
<robot name="restaurant_robot">

  <!-- =====================================================
                        MATERIALS
  ====================================================== -->

  <material name="body_green">
    <color rgba="0.16 0.62 0.20 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="black">
    <color rgba="0.08 0.08 0.08 1"/>
  </material>

  <material name="gray">
    <color rgba="0.75 0.75 0.75 1"/>
  </material>

  <material name="camera_black">
    <color rgba="0.12 0.12 0.12 1"/>
  </material>

  <material name="lidar_gray">
    <color rgba="0.45 0.45 0.45 1"/>
  </material>

  <!-- =====================================================
                        BASE
  ====================================================== -->

  <link name="base_link">

    <!-- Green Body -->
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.33 0.23 0.07"/>
      </geometry>
      <material name="body_green"/>
    </visual>

    <!-- Black Trim -->
    <visual>
      <origin xyz="0 0 0.038"/>
      <geometry>
        <box size="0.33 0.23 0.008"/>
      </geometry>
      <material name="black"/>
    </visual>

    <!-- White Shelf -->
    <visual>
      <origin xyz="0 0 0.040"/>
      <geometry>
        <box size="0.31 0.21 0.018"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.33 0.23 0.07"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="6"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.08"
        ixy="0"
        ixz="0"
        iyy="0.08"
        iyz="0"
        izz="0.08"/>
    </inertial>

  </link>

  <!-- =====================================================
                    LEFT WHEEL
  ====================================================== -->

  <link name="left_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>

  </link>

  <!-- =====================================================
                    RIGHT WHEEL
  ====================================================== -->

  <link name="right_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>

  </link>

  <!-- =====================================================
                     FRONT CASTER
  ====================================================== -->

  <link name="front_caster">

    <visual>
      <origin xyz="0 0 0.015"/>
      <geometry>
        <cylinder radius="0.008" length="0.03"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.012"/>
      </geometry>
      <material name="black"/>
    </visual>

  </link>

  <!-- =====================================================
                  REAR LEFT CASTER
  ====================================================== -->

  <link name="rear_left_caster">

    <visual>
      <origin xyz="0 0 0.015"/>
      <geometry>
        <cylinder radius="0.008" length="0.03"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.012"/>
      </geometry>
      <material name="black"/>
    </visual>

  </link>

  <!-- =====================================================
                  REAR RIGHT CASTER
  ====================================================== -->

  <link name="rear_right_caster">

    <visual>
      <origin xyz="0 0 0.015"/>
      <geometry>
        <cylinder radius="0.008" length="0.03"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.012"/>
      </geometry>
      <material name="black"/>
    </visual>

  </link>

  <!-- =====================================================
                     WHEEL JOINTS
  ====================================================== -->

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.115 -0.045"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.115 -0.045"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- =====================================================
                     CASTER JOINTS
  ====================================================== -->

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.125 0 -0.050"/>
</joint>

 <joint name="rear_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_caster"/>
    <origin xyz="-0.125 0.075 -0.050"/>
</joint>

<joint name="rear_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_caster"/>
    <origin xyz="-0.125 -0.075 -0.050"/>
</joint>

    <!-- =====================================================
                    SUPPORT PILLARS
  ====================================================== -->

  <link name="pillar_fl">
    <visual>
      <geometry>
        <cylinder radius="0.008" length="0.18"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="pillar_fr">
    <visual>
      <geometry>
        <cylinder radius="0.008" length="0.18"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="pillar_rl">
    <visual>
      <geometry>
        <cylinder radius="0.008" length="0.18"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="pillar_rr">
    <visual>
      <geometry>
        <cylinder radius="0.008" length="0.18"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- =====================================================
                    PILLAR JOINTS
  ====================================================== -->

  <joint name="pillar_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_fl"/>
    <origin xyz="0.12 0.085 0.13"/>
  </joint>

  <joint name="pillar_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_fr"/>
    <origin xyz="0.12 -0.085 0.13"/>
  </joint>

  <joint name="pillar_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_rl"/>
    <origin xyz="-0.12 0.085 0.13"/>
  </joint>

  <joint name="pillar_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_rr"/>
    <origin xyz="-0.12 -0.085 0.13"/>
  </joint>

  <!-- =====================================================
                        TOP TRAY
  ====================================================== -->

  <link name="top_tray">

    <visual>
      <geometry>
        <box size="0.34 0.24 0.02"/>
      </geometry>

      <material name="white"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.34 0.24 0.02"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>

      <inertia
        ixx="0.01"
        ixy="0"
        ixz="0"
        iyy="0.01"
        iyz="0"
        izz="0.01"/>
    </inertial>

  </link>

  <joint name="top_tray_joint" type="fixed">

    <parent link="base_link"/>
    <child link="top_tray"/>

    <origin xyz="0 0 0.21"/>

  </joint>

  <!-- =====================================================
                         CAMERA
  ====================================================== -->

  <link name="camera">

    <visual>

      <geometry>
        <box size="0.03 0.025 0.02"/>
      </geometry>

      <material name="camera_black"/>

    </visual>

    <collision>

      <geometry>
        <box size="0.03 0.025 0.02"/>
      </geometry>

    </collision>

    <inertial>

      <mass value="0.05"/>

      <origin xyz="0 0 0"/>

      <inertia
        ixx="0.00001"
        ixy="0"
        ixz="0"
        iyy="0.00001"
        iyz="0"
        izz="0.00001"/>

    </inertial>

  </link>

  <joint name="camera_joint" type="fixed">

    <parent link="top_tray"/>
    <child link="camera"/>

    <!-- Under the front edge of tray -->
    <origin xyz="0.10 0 -0.02"/>

  </joint>

    <!-- =====================================================
                        LiDAR BASE
  ====================================================== -->

  <link name="lidar_base">

    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.015"/>
      </geometry>

      <material name="lidar_gray"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.015"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.10"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0001"/>
    </inertial>

  </link>

  <joint name="lidar_base_joint" type="fixed">

    <parent link="top_tray"/>
    <child link="lidar_base"/>

    <origin xyz="0 0 0.018"/>

  </joint>

  <!-- =====================================================
                        LiDAR SENSOR
  ====================================================== -->

  <link name="lidar_sensor">

    <visual>

      <geometry>
        <cylinder radius="0.024" length="0.03"/>
      </geometry>

      <material name="lidar_blue">
  <color rgba="0.0 0.35 1.0 1"/>
</material>

    </visual>

    <collision>

      <geometry>
        <cylinder radius="0.024" length="0.03"/>
      </geometry>

    </collision>

    <inertial>

      <mass value="0.10"/>

      <origin xyz="0 0 0"/>

      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0001"/>

    </inertial>

  </link>

  <joint name="lidar_sensor_joint" type="fixed">

    <parent link="lidar_base"/>
    <child link="lidar_sensor"/>

    <origin xyz="0 0 0.0225"/>

  </joint>

</robot>